LLM_MODE=mock
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
LLM_TIMEOUT_SECONDS=45
EMBEDDING_PROVIDER=auto
EMBEDDING_MODEL=
EMBEDDING_TIMEOUT_SECONDS=20
EMBEDDING_FALLBACK_LOCAL=true
JD_PARSER_MODE=deterministic

# Persistence
# Use sqlite for quick local fallback, postgres for deployment/local PostgreSQL.
CAREER_AGENT_DB_PROVIDER=sqlite
CAREER_AGENT_DB_PATH=./data/career_agent_os.sqlite3
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=careerAgentOS
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
# DATABASE_URL=postgresql://postgres:password@localhost:5432/careerAgentOS
